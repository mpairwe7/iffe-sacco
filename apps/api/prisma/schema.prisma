generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ===== USER & AUTH =====
model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String?
  password  String
  role      String   @default("member") // admin | chairman | member | staff
  avatar    String?
  locale    String   @default("en") // en | lg
  isActive  Boolean  @default(true)
  lastLogin DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  member    Member?
  auditLogs AuditLog[]
  sessions  Session[]
  passwordResetTokens PasswordResetToken[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model Session {
  id         String   @id @default(uuid())
  userId     String
  expiresAt  DateTime
  revokedAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// ===== MEMBER =====
model Member {
  id          String   @id @default(uuid())
  memberId    String   @unique
  firstName   String
  lastName    String
  email       String
  phone       String
  gender      String?
  dateOfBirth DateTime?
  nationalId  String?
  occupation  String?
  address     String?
  city        String?
  district    String?
  country     String   @default("UG")
  status      String   @default("pending") // active | pending | inactive | suspended
  joinDate    DateTime @default(now())
  userId      String?  @unique
  shareCount  Int      @default(0)
  weddingSupportStatus    String   @default("not_received") // received | not_received
  weddingSupportDebt      Decimal  @default(0) @db.Decimal(15, 2)
  condolenceSupportStatus String   @default("not_received") // received | not_received
  condolenceSupportDebt   Decimal  @default(0) @db.Decimal(15, 2)
  remarks                 String?

  // Extended bio data (from IBDA Bio Data form)
  clan              String?
  totem             String?
  birthDistrict     String?
  birthVillage      String?
  ancestralDistrict String?
  ancestralVillage  String?
  residenceDistrict String?
  residenceVillage  String?
  placeOfWork       String?
  qualifications    String?
  fatherInfo        Json?
  motherInfo        Json?
  spouses           Json?
  children          Json?
  otherRelatives    Json?
  applicationId     String?  @unique

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User?        @relation(fields: [userId], references: [id])
  application Application? @relation(fields: [applicationId], references: [id])
  accounts    Account[]
  loans       Loan[]
  pledges     Pledge[]

  @@index([status])
  @@index([email])
  @@index([memberId])
  @@map("members")
}

// ===== ACCOUNT =====
model Account {
  id           String   @id @default(uuid())
  accountNo    String   @unique
  memberId     String
  type         String   @default("savings") // savings | current | fixed_deposit
  balance      Decimal  @default(0) @db.Decimal(15, 2)
  interestRate Decimal  @default(12) @db.Decimal(5, 2)
  status       String   @default("active") // active | dormant | frozen | closed
  lastActivity DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  member       Member        @relation(fields: [memberId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([memberId])
  @@index([status])
  @@index([accountNo])
  @@map("accounts")
}

// ===== TRANSACTION =====
model Transaction {
  id                String   @id @default(uuid())
  accountId         String
  type              String   // deposit | withdrawal | transfer | loan_repayment | loan_disbursement | interest_credit | fee
  amount            Decimal  @db.Decimal(18, 4)
  description       String?
  method            String   @default("cash") // cash | mobile_money | bank_transfer | cheque | internal
  reference         String?
  externalReference String?  // upstream payment gateway ref
  idempotencyKey    String?  @unique
  journalEntryId    String?  // backlink to double-entry journal (Phase 1+)
  reversalOfId      String?  // if this is a reversal, points to original
  status            String   @default("pending") // pending | completed | rejected | reversed
  processedBy       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  account       Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  journalEntry  JournalEntry? @relation(fields: [journalEntryId], references: [id])

  @@index([accountId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([journalEntryId])
  @@map("transactions")
}

// ===== LOAN =====
model Loan {
  id                 String   @id @default(uuid())
  memberId           String
  type               String   // business | personal | emergency | education | housing
  amount             Decimal  @db.Decimal(18, 4)
  balance            Decimal  @default(0) @db.Decimal(18, 4)
  interestRate       Decimal  @db.Decimal(7, 4)
  interestAccrued    Decimal  @default(0) @db.Decimal(18, 4)
  lateFeesAccrued    Decimal  @default(0) @db.Decimal(18, 4)
  term               Int      // months
  monthlyPayment     Decimal  @default(0) @db.Decimal(18, 4)
  nextPaymentDate    DateTime?
  lastAccrualAt      DateTime?
  overdueSince       DateTime?
  status             String   @default("pending") // pending | approved | active | paid | overdue | defaulted | rejected
  approvedBy         String?
  disbursedAt        DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([status])
  @@index([nextPaymentDate])
  @@index([overdueSince])
  @@map("loans")
}

// ===== EXPENSE =====
model Expense {
  id          String   @id @default(uuid())
  description String
  category    String
  amount      Decimal  @db.Decimal(15, 2)
  date        DateTime
  approvedBy  String?
  status      String   @default("pending") // pending | approved | rejected
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([status])
  @@index([date])
  @@map("expenses")
}

// ===== WELFARE PROGRAM =====
model WelfareProgram {
  id               String   @id @default(uuid())
  name             String
  description      String
  targetAmount     Decimal  @db.Decimal(15, 2)
  raisedAmount     Decimal  @default(0) @db.Decimal(15, 2)
  contributorCount Int      @default(0)
  status           String   @default("active") // active | completed | paused
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  pledges Pledge[]

  @@map("welfare_programs")
}

// ===== PLEDGE =====
model Pledge {
  id         String    @id @default(uuid())
  programId  String
  memberId   String
  amount     Decimal   @db.Decimal(18, 4)
  paidAmount Decimal   @default(0) @db.Decimal(18, 4)
  paidAt     DateTime?
  status     String    @default("pledged") // pledged | partially_paid | paid | cancelled
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt @default(now())

  program WelfareProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  member  Member         @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([programId])
  @@index([memberId])
  @@index([status])
  @@map("pledges")
}

// ===== AUDIT LOG =====
model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
  @@map("audit_logs")
}

// ===== BANK ACCOUNT =====
model BankAccount {
  id          String   @id @default(uuid())
  bankName    String
  accountName String
  accountNo   String
  branch      String?
  balance     Decimal  @default(0) @db.Decimal(15, 2)
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("bank_accounts")
}

// ===== DEPOSIT REQUEST =====
model DepositRequest {
  id          String   @id @default(uuid())
  memberId    String
  accountId   String
  amount      Decimal  @db.Decimal(15, 2)
  method      String   @default("cash")
  description String?
  status      String   @default("pending") // pending | approved | rejected
  processedBy String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([memberId])
  @@index([status])
  @@map("deposit_requests")
}

// ===== WITHDRAW REQUEST =====
model WithdrawRequest {
  id          String   @id @default(uuid())
  memberId    String
  accountId   String
  amount      Decimal  @db.Decimal(15, 2)
  method      String   @default("cash")
  reason      String?
  status      String   @default("pending") // pending | approved | rejected
  processedBy String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([memberId])
  @@index([status])
  @@map("withdraw_requests")
}

// ===== PAYMENT GATEWAY =====
model PaymentGateway {
  id       String  @id @default(uuid())
  name     String
  type     String  // mobile_money | bank | card | online
  currency String  @default("UGX")
  fee      String  @default("0%")
  isActive Boolean @default(false)
  config   Json?

  @@map("payment_gateways")
}

// ===== APPLICATION (Membership Application) =====
model Application {
  id                String   @id @default(uuid())

  // General Information
  fullName          String
  dateOfBirth       DateTime?
  sex               String?
  phone             String
  email             String?
  clan              String?
  totem             String?

  // Place of birth
  birthDistrict     String?
  birthCounty       String?
  birthSubCounty    String?
  birthParish       String?
  birthVillage      String?

  // Place of ancestral origin
  ancestralDistrict String?
  ancestralCounty   String?
  ancestralSubCounty String?
  ancestralParish   String?
  ancestralVillage  String?

  // Place of residence
  residenceDistrict String?
  residenceCounty   String?
  residenceSubCounty String?
  residenceParish   String?
  residenceVillage  String?

  // Work
  occupation        String?
  placeOfWork       String?
  qualifications    String?

  // Family (JSON)
  fatherInfo        Json?
  motherInfo        Json?
  spouses           Json?
  children          Json?
  otherRelatives    Json?

  // Document
  applicationLetterUrl  String?
  applicationLetterName String?

  // Workflow
  status            String   @default("pending") // pending | approved | rejected
  rejectionReason   String?
  reviewedBy        String?
  reviewedAt        DateTime?
  userId            String?  @unique
  memberId          String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  member            Member?

  @@index([status])
  @@index([email])
  @@map("applications")
}

// ===== SYSTEM SETTING =====
model Setting {
  id    String @id @default(uuid())
  key   String @unique
  value String

  @@map("settings")
}

// ===================================================================
// LEDGER (Phase 1 — double-entry bookkeeping)
// ===================================================================

// Chart of accounts. Seeded from packages/ledger/src/gl-accounts.ts at
// app boot; never mutated at runtime except by admin migrations.
model GlAccount {
  code        String   @id
  name        String
  type        String   // ASSET | LIABILITY | EQUITY | INCOME | EXPENSE
  normal      String   // DEBIT | CREDIT
  parentCode  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lines JournalLine[]

  @@index([type])
  @@map("gl_accounts")
}

// Append-only journal. Every row represents one atomic accounting event.
// idempotencyKey is unique — replays of the same logical operation return
// the existing entry instead of creating a duplicate.
model JournalEntry {
  id             String   @id @default(uuid())
  occurredAt     DateTime @default(now())
  postedAt       DateTime @default(now())
  idempotencyKey String   @unique
  description   String
  metadata       Json?
  workflowRunId  String?
  createdBy      String
  reversedById   String?  @unique
  createdAt      DateTime @default(now())

  lines          JournalLine[]
  transactions   Transaction[]
  reversedBy     JournalEntry? @relation("JournalReversal", fields: [reversedById], references: [id])
  reverses       JournalEntry? @relation("JournalReversal")

  @@index([occurredAt])
  @@index([workflowRunId])
  @@map("journal_entries")
}

// Individual debit or credit line within a journal entry. Exactly one of
// debit or credit is non-zero per row. Sum(debit) == sum(credit) is
// enforced at the application layer (enforced via JournalEntryBuilder).
model JournalLine {
  id              String   @id @default(uuid())
  entryId         String
  accountCode     String   // GL account code
  memberAccountId String?  // optional link to member's Account
  debit           Decimal  @default(0) @db.Decimal(18, 4)
  credit          Decimal  @default(0) @db.Decimal(18, 4)
  currency        String   @default("UGX")
  createdAt       DateTime @default(now())

  entry   JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account GlAccount    @relation(fields: [accountCode], references: [code])

  @@index([entryId])
  @@index([accountCode])
  @@index([memberAccountId])
  @@map("journal_lines")
}

// HTTP-level idempotency dedupe. POST requests with an Idempotency-Key
// header hit this table first; a replay with the same key + route returns
// the cached response body.
model IdempotencyKey {
  key          String   @id
  routeHash    String
  requestHash  String
  responseBody Json?
  statusCode   Int?
  userId       String?
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  @@index([expiresAt])
  @@map("idempotency_keys")
}

// Workflow runs (Phase 1). Lightweight crash-safe saga log that sits in
// front of WDK-style workflows until Vercel Workflow DevKit integration
// lands. Each step is logged so a resumption can pick up where it left off.
model WorkflowRun {
  id             String   @id @default(uuid())
  type           String   // deposit | withdrawal | loan_disbursement | ...
  status         String   @default("running") // running | completed | failed | compensated
  idempotencyKey String   @unique
  input          Json
  output         Json?
  error          String?
  startedBy      String
  startedAt      DateTime @default(now())
  finishedAt     DateTime?
  steps          WorkflowStep[]

  @@index([status])
  @@index([type])
  @@map("workflow_runs")
}

model WorkflowStep {
  id          String   @id @default(uuid())
  runId       String
  name        String
  status      String   // running | completed | failed
  input       Json?
  output      Json?
  error       String?
  startedAt   DateTime @default(now())
  finishedAt  DateTime?

  run WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@map("workflow_steps")
}

// ===================================================================
// PHASE 8: AI assistant + notifications + anomaly inbox
// ===================================================================

model AssistantConversation {
  id        String   @id @default(uuid())
  userId    String
  title     String?
  audience  String   // member | staff | chairman | admin
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages AssistantMessage[]

  @@index([userId])
  @@map("assistant_conversations")
}

model AssistantMessage {
  id             String   @id @default(uuid())
  conversationId String
  role           String   // user | assistant | system | tool
  content        String
  toolCalls      Json?
  tokensIn       Int?
  tokensOut      Int?
  model          String?
  createdAt      DateTime @default(now())

  conversation AssistantConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("assistant_messages")
}

model PushSubscription {
  id         String   @id @default(uuid())
  userId     String
  endpoint   String   @unique
  p256dh     String
  auth       String
  userAgent  String?
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([userId])
  @@map("push_subscriptions")
}

model NotificationPreference {
  userId                      String  @id
  pushEnabled                 Boolean @default(true)
  emailEnabled                Boolean @default(true)
  notifyTransactionPosted     Boolean @default(true)
  notifyLoanPaymentDue        Boolean @default(true)
  notifyLoanApproved          Boolean @default(true)
  notifySecurityAlert         Boolean @default(true)
  notifyWelfareUpdate         Boolean @default(true)
  notifyAssistantMessage      Boolean @default(false)
  updatedAt                   DateTime @updatedAt

  @@map("notification_preferences")
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  type      String    // transaction_posted | loan_due | loan_approved | security | welfare | assistant
  title     String
  body      String
  url       String?   // deep link
  readAt    DateTime?
  sentVia   String[]  @default([])  // push | email | in_app
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
  @@index([createdAt])
  @@map("notifications")
}

model AnomalyAlert {
  id              String   @id @default(uuid())
  memberId        String?
  memberAccountId String?
  transactionId   String?
  score           Int      // 0-100
  action          String   // allow | review | block
  signals         Json
  reasoning       String?
  status          String   @default("open") // open | reviewing | resolved_legit | resolved_fraud
  reviewedBy      String?
  reviewedAt      DateTime?
  resolutionNote  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([memberId])
  @@index([createdAt])
  @@map("anomaly_alerts")
}

// ===================================================================
// PHASE 9: Passkeys (WebAuthn) + user locale
// ===================================================================

model Passkey {
  id              String   @id @default(uuid())
  userId          String
  credentialId    String   @unique
  publicKey       Bytes
  counter         BigInt   @default(0)
  deviceType      String?  // singleDevice | multiDevice
  backedUp        Boolean  @default(false)
  transports      String[] @default([]) // usb | nfc | ble | hybrid | internal
  nickname        String?
  lastUsedAt      DateTime?
  createdAt       DateTime @default(now())

  @@index([userId])
  @@map("passkeys")
}

model WebAuthnChallenge {
  id        String   @id @default(uuid())
  userId    String?
  challenge String   @unique
  kind      String   // registration | authentication
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("webauthn_challenges")
}
