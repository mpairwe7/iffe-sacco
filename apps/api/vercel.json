{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd ../.. && bun install && cd apps/api && npx prisma generate",
  "buildCommand": "bash scripts/vercel-build.sh",
  "rewrites": [
    { "source": "/api/v1/(.*)", "destination": "/api" },
    { "source": "/api/v1", "destination": "/api" }
  ]
}
