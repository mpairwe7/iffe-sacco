{
  "name": "@iffe/api",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "exports": {
    "./app": "./src/app.ts",
    "./dist/app": "./dist/app.js"
  },
  "scripts": {
    "dev": "bun --bun run --watch src/index.ts",
    "start": "bun --bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun && bun build src/app.ts --outdir dist --target node --external @prisma/client --external @prisma/adapter-neon --external @neondatabase/serverless && node scripts/copy-deps.mjs",
    "db:generate": "bunx prisma generate",
    "db:migrate": "bunx prisma migrate dev",
    "db:push": "bunx prisma db push",
    "db:studio": "bunx prisma studio",
    "db:seed": "bun run prisma/seed.ts",
    "ledger:backfill": "bun run scripts/backfill-ledger.ts",
    "ledger:backfill:dry": "bun run scripts/backfill-ledger.ts --dry-run",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@hono/zod-validator": "^0.5",
    "@iffe/assistant": "workspace:*",
    "@iffe/ledger": "workspace:*",
    "@iffe/shared": "workspace:*",
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^7.5.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.4",
    "@simplewebauthn/server": "^13.1.0",
    "bcryptjs": "^3",
    "hono": "^4",
    "jose": "^6",
    "pg": "^8.20.0",
    "pino": "^9.5.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2",
    "@types/node": "^25",
    "@types/pg": "^8.20.0",
    "@types/web-push": "^3.6.4",
    "pino-pretty": "^13.0.0",
    "prisma": "^7.4",
    "typescript": "^5"
  }
}
