# ===== Core =====
NODE_ENV=development
PORT=4000

# Neon Postgres connection string (pooled variant preferred for serverless).
DATABASE_URL=<neon-postgres-connection-string>

# ===== Auth & sessions =====
# Strong secret used to sign session JWTs. Rotate quarterly.
# Generate with: openssl rand -base64 48
JWT_SECRET=<generate-secure-random>

# (Reserved for future refresh-token support.)
JWT_REFRESH_SECRET=<generate-secure-random>

# Hours a regular session token stays valid.
SESSION_TTL_HOURS=24
# Days a "remember me" session stays valid.
REMEMBER_ME_SESSION_TTL_DAYS=7
# Minutes a password reset token is valid.
PASSWORD_RESET_TTL_MINUTES=30

# ===== CORS =====
# Comma-separated list. First entry is the default echoed for same-site calls.
CORS_ORIGIN=http://localhost:3000
APP_BASE_URL=http://localhost:3000

# ===== Rate limiting =====
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_ATTEMPTS=5

# ===== Observability (Phase 0) =====
LOG_LEVEL=debug
APP_VERSION=dev
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# ===== Credentials encryption (Phase 2) =====
# 32-byte key (base64) used as KEK for payment-gateway credential envelope encryption.
# Generate with: openssl rand -base64 32
CREDENTIALS_KEK=

# ===== Email (Phase 2) =====
# Resend API key for password reset + notification emails.
RESEND_API_KEY=
RESEND_FROM_EMAIL="IFFE SACCO <no-reply@sacco.example.org>"
