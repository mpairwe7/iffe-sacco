{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "resolveJsonModule": true,
    "types": ["node"],
    "paths": {
      "@iffe/shared": ["../../packages/shared/src"],
      "@iffe/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["./**/*.ts", "../src/**/*.ts", "../generated/**/*.ts"]
}
