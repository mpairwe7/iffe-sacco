# ===== Web app public config =====
# Base URL the browser uses to reach the API. In unified Vercel deployments
# this is the same-origin proxy path; in split deployments it's a full URL.
NEXT_PUBLIC_API_URL=/api/v1

# Human-readable build version shown in UI/health responses.
NEXT_PUBLIC_APP_VERSION=dev

# ===== Web app server-only config =====
# Required: used by the proxy route to verify JWTs before calling the API.
JWT_SECRET=<generate-with-openssl-rand-base64-48>

# Comma-separated list of origins allowed to hit the API proxy.
# Example: https://sacco.example.org,https://admin.sacco.example.org
ALLOWED_ORIGINS=http://localhost:3000

# Feature flag store (Phase 0 scaffold — fill in when Edge Config is provisioned).
EDGE_CONFIG=

# ===== Observability (Phase 0) =====
# Sentry: set from the Vercel Marketplace integration or your own project.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0
SENTRY_AUTH_TOKEN=<source-maps-upload-only>

# ===== Notes =====
# * Never commit a populated .env or .env.local — only .env.example.
# * Production values are managed with `vercel env add` or the dashboard.
